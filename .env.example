# 🧠 FlowMind AI - Environment Variables Template
# Copy this file to '.env.local' and fill in your actual credentials.
# Do NOT commit '.env.local' to source control.

# Google Gemini API Key: Required for the AI Productivity Coach, Prioritizer, and Planner.
# Retrieve your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# App URL: The hosting location of this application.
# Set this to http://localhost:3000 for standard local development.
APP_URL=http://localhost:3000
